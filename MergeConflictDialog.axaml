<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GitDesk.MergeConflictDialog"
        Title="Merge Conflict"
        Width="1540"
        Height="940"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterOwner">
    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox.merge-text">
            <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Courier New" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Styles>

    <DockPanel Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                Padding="8,6">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding TitleText}" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SummaryText}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Classes="toolbar" Content="Use Ours File" Click="OnUseOursClicked" />
                <Button Grid.Column="2" Classes="toolbar" Content="Use Theirs File" Click="OnUseTheirsClicked" />
                <Button Grid.Column="3" Classes="toolbar" Content="Save" Click="OnSaveClicked" />
                <Button Grid.Column="4" Classes="toolbar" Content="Mark Resolved" Click="OnMarkResolvedClicked" />
                <Button Grid.Column="5" Classes="toolbar" Content="Close" Click="OnCloseClicked" />
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,5,*,5,*" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="5" />
                <RowDefinition Height="132" />
                <RowDefinition Height="{Binding ResultSplitterHeight}" />
                <RowDefinition Height="{Binding ResultRowHeight}" />
                <RowDefinition Height="{Binding ResultRestoreRowHeight}" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="6,3" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Classes="header" Text="{Binding BaseHeaderText}" />
                    </Border>
                    <TextBox Classes="merge-text" Text="{Binding BaseContent}" IsReadOnly="True" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Width="5" Background="{DynamicResource DividerStrokeColorDefaultBrush}" ResizeDirection="Columns" />

            <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="6,3" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Classes="header" Text="{Binding OursHeaderText}" />
                    </Border>
                    <TextBox Classes="merge-text" Text="{Binding OursContent}" IsReadOnly="True" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="3" Width="5" Background="{DynamicResource DividerStrokeColorDefaultBrush}" ResizeDirection="Columns" />

            <Border Grid.Row="0" Grid.Column="4" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="6,3" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Classes="header" Text="{Binding TheirsHeaderText}" />
                    </Border>
                    <TextBox Classes="merge-text" Text="{Binding TheirsContent}" IsReadOnly="True" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Height="5" Background="{DynamicResource DividerStrokeColorDefaultBrush}" ResizeDirection="Rows" />

            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <Grid RowDefinitions="Auto,*" ColumnDefinitions="360,*">
                    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Padding="6,3" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Column="0" Classes="header" Text="{Binding MergeSummaryText}" />
                            <Button Grid.Column="1" Classes="toolbar" Content="Prev" Click="OnPreviousConflictClicked" />
                            <Button Grid.Column="2" Classes="toolbar" Content="Next" Click="OnNextConflictClicked" />
                            <Button Grid.Column="3" Classes="toolbar" Content="Selected Ours" Click="OnApplySelectedOursClicked" />
                            <Button Grid.Column="4" Classes="toolbar" Content="Selected Theirs" Click="OnApplySelectedTheirsClicked" />
                            <Button Grid.Column="5" Classes="toolbar" Content="Selected Both" Click="OnApplySelectedBothClicked" />
                            <Button Grid.Column="6" Classes="toolbar" Content="All Ours" Click="OnApplyAllOursClicked" />
                            <Button Grid.Column="7" Classes="toolbar" Content="All Theirs" Click="OnApplyAllTheirsClicked" />
                            <Button Grid.Column="8" Classes="toolbar" Content="All Both" Click="OnApplyAllBothClicked" />
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Grid.Column="0"
                              ItemsSource="{Binding ConflictBlocks}"
                              SelectedItem="{Binding SelectedConflictBlock, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              GridLinesVisibility="All"
                              HeadersVisibility="Column"
                              RowHeight="26"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Block" Binding="{Binding DisplayName}" Width="90" />
                            <DataGridTextColumn Header="Ours" Binding="{Binding OursPreview}" Width="130" />
                            <DataGridTextColumn Header="Theirs" Binding="{Binding TheirsPreview}" Width="130" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBox Grid.Row="1"
                             Grid.Column="1"
                             Classes="merge-text"
                             Text="{Binding WorkingContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource TextControlBackground}" />
                </Grid>
            </Border>

            <GridSplitter Grid.Row="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="5"
                          Height="5"
                          Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                          ResizeDirection="Rows"
                          IsVisible="{Binding IsResultVisible}" />

            <Border Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="5"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    IsVisible="{Binding IsResultVisible}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="6,3" Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0" Classes="header" Text="{Binding WorkingHeaderText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedConflictText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Content="{Binding ResultVisibilityIcon}"
                                    Width="28"
                                    Height="22"
                                    Margin="8,0,0,0"
                                    Padding="0"
                                    ToolTip.Tip="{Binding ResultVisibilityText}"
                                    Click="OnToggleResultClicked" />
                        </Grid>
                    </Border>
                    <TextBox Classes="merge-text"
                             Text="{Binding WorkingContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsVisible="{Binding IsResultVisible}" />
                </DockPanel>
            </Border>

            <Border Grid.Row="5"
                    Grid.Column="0"
                    Grid.ColumnSpan="5"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    IsVisible="{Binding IsResultHidden}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Merged Result hidden"
                               Margin="8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <Button Grid.Column="1"
                            Content="{Binding ResultVisibilityIcon}"
                            Width="28"
                            Height="22"
                            Margin="0,3,6,3"
                            Padding="0"
                            ToolTip.Tip="{Binding ResultVisibilityText}"
                            Click="OnToggleResultClicked" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
